# ClickUp Task Manager Bot - Environment Configuration

# ============ TELEGRAM ============
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ============ SCHEDULER ============
# Enable/disable the hourly task scheduler
SCHEDULER_ENABLED=true

# Cron schedule for the scheduler
# Default: "5 10-19 * * *" = Every hour from 10:00 to 19:00 (at minute 5)
# To run every minute, use: "* * * * *"
# Format: "[minute] [hour] [day of month] [month] [day of week]"
# Examples:
#   "* * * * *"         = Every minute (useful for testing)
#   "0 */6 * * *"       = Every 6 hours
#   "0 9-18 * * 1-5"    = Every hour 9:00-18:00, Monday-Friday
#   "0 10 * * *"        = Daily at 10:00
SCHEDULER_CRON=5 10-19 * * *

# Users to process per batch (higher = faster but more API pressure)
# Recommended: 10-20 for most cases
SCHEDULER_BATCH_SIZE=10

# Delay between batches in milliseconds (prevents API rate limiting)
# Recommended: 1000-2000
SCHEDULER_BATCH_DELAY_MS=1000

# ============ LOGGING ============
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Optional: Log file path (logs will be written to ./logs/ directory)
# Leave empty to disable file logging
# Example: bot.log
LOG_FILE=

# ============ CLICKUP ============
# Note: Each user provides their own ClickUp API token
# No global token needed

# ============ NODE ============
# Production or development mode
NODE_ENV=production

# Port for monitoring/health checks (optional if you add Express server)
PORT=3000
